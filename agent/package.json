{
  "name": "phantom-agent",
  "version": "1.0.0",
  "description": "PhantomOS Windows Agent - connects Windows PC to PhantomBridge",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "start": "node index.js",
    "build": "pkg . --targets node18-win-x64 --output dist/PhantomAgent.exe --compress GZip",
    "install-service": "node service.js install",
    "uninstall-service": "node service.js uninstall"
  },
  "dependencies": {},
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "targets": ["node18-win-x64"],
    "outputPath": "dist",
    "assets": ["config.json"],
    "scripts": ["index.js"]
  }
}
